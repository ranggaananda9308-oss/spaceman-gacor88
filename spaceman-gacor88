<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SPACEMAN SIMULATOR</title>
    <style>
        body { background: #000; color: white; font-family: monospace; text-align: center; margin: 0; }
        #multiplier { font-size: 2.5em; color: #ffff00; margin: 10px 0; font-weight: bold; }
        #game-area { position: relative; width: 100%; height: 350px; background: url('https://i.ibb.co/5R6Ym0x/space-bg.jpg'); background-size: cover; overflow: hidden; border-top: 2px solid #333; border-bottom: 2px solid #333; }
        #spaceman { position: absolute; width: 50px; bottom: 20%; left: 10%; transition: bottom 0.1s, left 0.1s; }
        .info-bar { background: #111; padding: 10px; font-size: 0.9em; text-align: left; }
        input { width: 60%; padding: 8px; margin: 10px; background: #fff; border: none; font-weight: bold; }
        .btn-fly { background: #00aeef; color: white; border: none; width: 85%; padding: 12px; font-weight: bold; margin-bottom: 5px; }
        .btn-cashout { background: #ff9900; color: black; border: none; width: 85%; padding: 12px; font-weight: bold; display: none; }
    </style>
</head>
<body>
    <div style="padding: 10px;">
        <h3>👨‍🚀 SPACEMAN SIMULATOR</h3>
        <div class="info-bar">
            Saldo Virtual: <span id="balance">1000</span><br>
            Taruhan: <input type="number" id="bet" value="10">
        </div>
        <div id="multiplier">Perkalian: 1.00x</div>
        <p id="status">Siap Mengangkasa!</p>
    </div>

    <div id="game-area">
        <img id="spaceman" src="https://i.postimg.cc/8PzZ8qBC/spaceman-emoji.png" alt="👨‍🚀">
    </div>

    <div style="padding: 20px;">
        <button id="btn-play" class="btn-fly" onclick="startFly()">PASANG TARUHAN & TERBANG</button>
        <button id="btn-wd" class="btn-cashout" onclick="cashout()">AMBIL UNTUNG (CASHOUT)</button>
    </div>

    <script>
        const urlParams = new URLSearchParams(window.location.search);
        let control = urlParams.get('control') || "NORMAL"; 
        let isFlying = false, currentMult = 1.0, crashAt = 0, balance = 1000;

        function startFly() {
            if(isFlying) return;
            let bet = document.getElementById('bet').value;
            if(bet > balance) return alert("Saldo Gak Cukup!");

            // --- LOGIKA KONTROL JARAK JAUH ---
            if (control === "rampok") {
                crashAt = 1.01 + (Math.random() * 0.15); // Pasti meledak di bawah 1.15x
            } else if (control === "gacor") {
                crashAt = 10.0 + (Math.random() * 40); // Terbang sampe langit ke-7
            } else {
                crashAt = 1.2 + (Math.random() * 5); // Normal
            }

            isFlying = true; currentMult = 1.0;
            document.getElementById('btn-play').style.display = 'none';
            document.getElementById('btn-wd').style.display = 'block';
            document.getElementById('status').innerText = "Spaceman Mengangkasa!";
            animate();
        }

        function animate() {
            if(!isFlying) return;
            currentMult += 0.01 * (currentMult / 4);
            document.getElementById('multiplier').innerText = "Perkalian: " + currentMult.toFixed(2) + "x";
            
            // Gerakan Spaceman (Naik & Maju)
            let moveY = 20 + (currentMult * 5);
            let moveX = 10 + (currentMult * 3);
            document.getElementById('spaceman').style.bottom = (moveY > 75 ? 75 : moveY) + "%";
            document.getElementById('spaceman').style.left = (moveX > 70 ? 70 : moveX) + "%";

            if(currentMult >= crashAt) {
                isFlying = false;
                alert("BOOM! MELEDAK DI " + currentMult.toFixed(2) + "x");
                location.reload();
            } else {
                requestAnimationFrame(animate);
            }
        }

        function cashout() {
            if(!isFlying) return;
            let profit = document.getElementById('bet').value * currentMult;
            alert("Berhasil WD! Lu dapet: " + profit.toFixed(0));
            isFlying = false;
            location.reload();
        }
    </script>
</body>
</html>
